{
  "name": "kadoui",
  "license": "MIT",
  "scripts": {
    "build:react": "pnpm --filter @kadoui/react build",
    "publish:react": "pnpm --filter @kadoui/react publish",
    "publish:tailwind": "pnpm --filter @kadoui/tailwindcss publish",
    "dev:next": "rm -rf apps/next-playground/.next/ && pnpm --filter next-playground dev",
    "dev:next:r": "rm -rf apps/next-playground/.next/ && pnpm --filter next-playground dev:r",
    "dev:next:h": "rm -rf apps/next-playground/.next/ && pnpm --filter next-playground dev:h",
    "dev:vanilla": "pnpm --filter vanilla-playground dev",
    "dev:docs": "rm -rf apps/kadoui-documentation/.next/ && pnpm --filter kadoui-documentation dev",
    "build:docs": "pnpm --filter kadoui-documentation build"
  },
  "packageManager": "pnpm@11.4.0"
}
